#!/bin/sh
# pre-commit — Enforce doc sync before every commit.
# Installed via: git config core.hooksPath hooks

echo ""
echo "=== pre-commit: checking doc sync ==="
echo ""

bash done_check.sh
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "=== COMMIT REJECTED ==="
  echo "Fix the issues above, stage changes, and commit again."
  echo "To bypass (emergency only): git commit --no-verify"
  echo ""
  exit 1
fi

echo "=== pre-commit: OK ==="
exit 0